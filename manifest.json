<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0369a1">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="PoolCheck">
<link rel="manifest" href="manifest.json">
<link rel="apple-touch-icon" href="icons/icon-192x192.png">
<title>PoolCheck</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap');

  :root {
    --water: #0ea5e9;
    --deep: #0c4a6e;
    --surface: #f0f9ff;
    --text: #0f172a;
    --muted: #64748b;
    --border: #e0f2fe;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--surface);
    height: 100dvh;
    display: flex;
    flex-direction: column;
    color: var(--text);
    overflow: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    top: 0; left: 0; right: 0; height: 240px;
    background: linear-gradient(160deg, #0369a1 0%, #0ea5e9 50%, #38bdf8 100%);
    z-index: 0;
    clip-path: ellipse(120% 100% at 50% 0%);
  }

  body::after {
    content: '';
    position: fixed;
    top: 0; left: -50%; right: -50%; height: 260px;
    background: repeating-linear-gradient(transparent 0px, transparent 18px, rgba(255,255,255,0.07) 18px, rgba(255,255,255,0.07) 20px);
    z-index: 1;
    animation: ripple 4s ease-in-out infinite;
    clip-path: ellipse(120% 100% at 50% 0%);
  }

  @keyframes ripple {
    0%,100% { transform: translateX(0) scaleY(1); }
    50% { transform: translateX(3%) scaleY(1.03); }
  }

  .header {
    position: relative; z-index: 10;
    padding: calc(env(safe-area-inset-top) + clamp(20px, 5vh, 48px)) 24px clamp(8px, 2vh, 16px);
    text-align: center; color: white;
    flex-shrink: 0;
  }

  .header h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(32px, 8vw, 52px);
    letter-spacing: clamp(2px, 1vw, 4px); line-height: 1;
    text-shadow: 0 2px 20px rgba(0,0,0,0.2);
  }

  .header p {
    font-size: clamp(10px, 2.5vw, 13px); font-weight: 300; opacity: 0.85;
    margin-top: 4px; letter-spacing: 1px; text-transform: uppercase;
  }

  .tab-nav {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 100;
    display: flex; gap: 8px;
    padding: clamp(6px, 1.5vh, 10px) 16px calc(clamp(6px, 1.5vh, 10px) + env(safe-area-inset-bottom));
    max-width: 480px; margin: 0 auto;
    background: rgba(3, 105, 161, 0.97);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-top: 1px solid rgba(255,255,255,0.15);
  }

  .tab-btn {
    flex: 1; padding: clamp(7px, 1.8vw, 10px); border: none; border-radius: 12px;
    font-family: 'Bebas Neue', sans-serif; font-size: clamp(14px, 3.5vw, 17px); letter-spacing: 1.5px;
    cursor: pointer; transition: all 0.2s; -webkit-tap-highlight-color: transparent;
  }
  .tab-btn.active { background: white; color: var(--deep); box-shadow: 0 4px 16px rgba(0,0,0,0.12); }
  .tab-btn:not(.active) { background: rgba(255,255,255,0.2); color: white; }

  .hc {
    display: inline-block; background: var(--water); color: white;
    font-family: 'DM Sans', sans-serif; font-size: 11px; font-weight: 600;
    padding: 1px 7px; border-radius: 10px; margin-left: 4px; vertical-align: middle;
  }
  .tab-btn.active .hc { background: var(--deep); }

  .page { display: none; flex: 1; overflow: hidden; }
  .page.active { display: flex; flex-direction: column; }

  .scroll-area {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding-bottom: calc(var(--tab-bar-h, 65px) + env(safe-area-inset-bottom) + 8px);
  }

  .main {
    position: relative; z-index: 10;
    padding: 0 clamp(10px, 3vw, 16px) 16px;
    max-width: 480px; margin: 0 auto; width: 100%;
  }

  /* ── CALIBRATION WIZARD ── */
  .wizard-card {
    background: white; border-radius: 24px;
    padding: clamp(14px, 3.5vw, 24px);
    box-shadow: 0 8px 32px rgba(14,165,233,0.15); margin-bottom: 12px;
  }

  .wizard-card h3 {
    font-family: 'Bebas Neue', sans-serif; font-size: 22px;
    letter-spacing: 2px; color: var(--deep); margin-bottom: 8px;
  }

  .wizard-card p { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 14px; }

  .steps-indicator {
    display: flex; gap: 6px; margin-bottom: 18px;
  }

  .step-dot {
    flex: 1; height: 4px; border-radius: 2px; background: #e0f2fe;
    transition: background 0.3s;
  }
  .step-dot.done { background: var(--ok, #10b981); }
  .step-dot.active { background: var(--water); }

  /* pad region selector */
  .region-wrap {
    position: relative; border-radius: 14px; overflow: hidden;
    background: #000; margin-bottom: 14px; cursor: crosshair;
    touch-action: none;
  }

  .region-wrap canvas { display: block; width: 100%; }

  .selection-box {
    position: absolute; border: 2px solid #facc15;
    background: rgba(250,204,21,0.15); pointer-events: none;
    display: none;
  }

  .pad-label-overlay {
    position: absolute; top: 6px; left: 6px;
    background: rgba(0,0,0,0.6); color: #facc15;
    font-family: 'Bebas Neue', sans-serif; font-size: 16px;
    letter-spacing: 1px; padding: 3px 10px; border-radius: 8px;
  }

  .instruction-row {
    display: flex; align-items: center; gap: 10px;
    background: #fffbeb; border: 1px solid #fde68a;
    border-radius: 12px; padding: 10px 14px; margin-bottom: 12px;
    font-size: 13px; color: #92400e; line-height: 1.4;
  }

  .instruction-row .icon { font-size: 20px; flex-shrink: 0; }

  .wizard-btn {
    width: 100%; padding: 14px;
    background: linear-gradient(135deg, #0369a1, #0ea5e9);
    color: white; border: none; border-radius: 14px;
    font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 2px;
    cursor: pointer; transition: all 0.2s;
    box-shadow: 0 4px 16px rgba(14,165,233,0.35);
    -webkit-tap-highlight-color: transparent;
  }
  .wizard-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .wizard-btn.secondary {
    background: white; color: var(--deep);
    border: 2px solid var(--border); box-shadow: none;
    margin-top: 8px; font-size: 17px;
  }

  /* Sampled color swatches */
  .swatch-row {
    display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px;
  }

  .swatch {
    width: 40px; height: 40px; border-radius: 8px;
    border: 2px solid rgba(0,0,0,0.1);
    display: flex; align-items: center; justify-content: center;
    font-size: 10px; font-weight: 600; color: white;
    text-shadow: 0 1px 2px rgba(0,0,0,0.5);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  /* ── UPLOAD CARD ── */
  .upload-card {
    background: white; border-radius: 24px; padding: clamp(16px, 4vw, 28px) clamp(14px, 4vw, 24px);
    box-shadow: 0 8px 32px rgba(14,165,233,0.15), 0 2px 8px rgba(0,0,0,0.06);
    margin-bottom: 16px;
  }

  .upload-zone {
    border: 2px dashed #bae6fd; border-radius: 16px; padding: clamp(18px, 5vh, 32px) 20px;
    text-align: center; cursor: pointer; transition: all 0.2s;
    background: #f0f9ff; position: relative; overflow: hidden;
  }
  .upload-zone:active { background: #e0f2fe; border-color: var(--water); }
  .upload-zone input[type="file"] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer;
    width: 100%; height: 100%; font-size: 16px;
  }
  .upload-icon { font-size: clamp(28px, 7vw, 40px); margin-bottom: clamp(6px, 1.5vh, 10px); display: block; }
  .upload-zone h3 { font-size: 16px; font-weight: 600; color: var(--deep); margin-bottom: 4px; }
  .upload-zone p { font-size: 13px; color: var(--muted); }

  /* Strip canvas preview */
  #strip-preview-wrap {
    display: none; margin-top: 14px; position: relative;
  }

  #strip-canvas {
    width: 100%; border-radius: 14px; display: block;
    cursor: crosshair; touch-action: none;
  }

  .pad-marker {
    position: absolute; border: 2px solid #facc15;
    border-radius: 4px; pointer-events: none;
    background: rgba(250,204,21,0.2);
  }

  .pad-marker-label {
    position: absolute; top: -18px; left: 0;
    font-size: 10px; font-weight: 700;
    color: #facc15; white-space: nowrap;
    text-shadow: 0 1px 2px rgba(0,0,0,0.8);
  }

  .change-btn {
    position: absolute; top: 6px; right: 6px;
    background: rgba(0,0,0,0.6); color: white; border: none;
    border-radius: 20px; padding: 4px 12px; font-size: 12px;
    cursor: pointer; font-family: 'DM Sans', sans-serif;
  }

  .analyze-btn {
    width: 100%; margin-top: 14px; padding: 18px;
    background: linear-gradient(135deg, #0369a1, #0ea5e9);
    color: white; border: none; border-radius: 14px;
    font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px;
    cursor: pointer; transition: all 0.2s;
    box-shadow: 0 4px 16px rgba(14,165,233,0.4);
    display: none; -webkit-tap-highlight-color: transparent;
  }
  .analyze-btn:active { transform: scale(0.98); }
  .analyze-btn:disabled { opacity: 0.6; }

  /* Pad selection mode */
  .pad-select-hint {
    display: none; background: #eff6ff; border: 1px solid #bfdbfe;
    border-radius: 12px; padding: 10px 14px; margin-top: 10px;
    font-size: 13px; color: var(--deep); line-height: 1.5;
  }

  .error-card {
    background: #fef2f2; border: 1px solid #fecaca;
    border-radius: 16px; padding: 14px; color: #991b1b;
    font-size: 13px; line-height: 1.6; display: none; margin-top: 12px;
  }

  /* ── RESULTS ── */
  #results { display: none; }

  .results-header {
    font-family: 'Bebas Neue', sans-serif; font-size: 28px;
    letter-spacing: 2px; color: var(--deep); margin-bottom: 12px; padding: 0 4px;
  }

  .param-card {
    background: white; border-radius: 20px; padding: clamp(12px, 3vw, 20px);
    margin-bottom: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    display: flex; align-items: center; gap: 16px;
    animation: slideUp 0.4s ease both;
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .param-card:nth-child(2) { animation-delay: 0.05s; }
  .param-card:nth-child(3) { animation-delay: 0.10s; }
  .param-card:nth-child(4) { animation-delay: 0.15s; }

  .status-dot {
    width: 52px; height: 52px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0; position: relative;
  }
  .status-ok .status-dot { background: #d1fae5; }
  .status-low .status-dot { background: #fef3c7; }
  .status-high .status-dot { background: #fee2e2; }
  .status-unknown .status-dot { background: #f1f5f9; }

  /* Sampled color chip on the dot */
  .color-chip {
    position: absolute; bottom: -2px; right: -2px;
    width: 18px; height: 18px; border-radius: 50%;
    border: 2px solid white;
  }

  .param-info { flex: 1; min-width: 0; }
  .param-name { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--muted); margin-bottom: 2px; }
  .param-value { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 1px; line-height: 1; color: var(--text); }
  .param-unit { font-family: 'DM Sans', sans-serif; font-size: 13px; color: var(--muted); margin-left: 3px; }
  .param-range { font-size: 12px; color: var(--muted); margin-top: 2px; }
  .param-confidence { font-size: 11px; margin-top: 3px; }

  .status-badge {
    font-size: 11px; font-weight: 600; padding: 4px 10px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; flex-shrink: 0;
  }
  .status-ok .status-badge { background: #d1fae5; color: #065f46; }
  .status-low .status-badge { background: #fef3c7; color: #92400e; }
  .status-high .status-badge { background: #fee2e2; color: #991b1b; }
  .status-unknown .status-badge { background: #f1f5f9; color: #475569; }

  .advice-card {
    background: linear-gradient(135deg, #0c4a6e, #0369a1);
    color: white; border-radius: 20px; padding: clamp(14px, 3vw, 20px);
    margin-bottom: 12px; animation: slideUp 0.4s 0.2s ease both;
  }
  .advice-card h3 { font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 1.5px; margin-bottom: 8px; }
  .advice-card p { font-size: 14px; line-height: 1.6; opacity: 0.9; }

  .new-test-btn {
    width: 100%; padding: 16px; background: white; border: 2px solid var(--border);
    border-radius: 14px; font-family: 'Bebas Neue', sans-serif;
    font-size: 20px; letter-spacing: 2px; color: var(--deep); cursor: pointer;
    animation: slideUp 0.4s 0.25s ease both; -webkit-tap-highlight-color: transparent;
  }

  /* ── HISTORY ── */
  .history-empty { text-align: center; padding: 60px 24px; color: var(--muted); }
  .history-empty .ei { font-size: 48px; margin-bottom: 12px; }
  .history-empty h3 { font-size: 18px; font-weight: 600; color: var(--deep); margin-bottom: 6px; }

  .history-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 14px; padding: 0 2px;
  }
  .history-title { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 2px; color: var(--deep); }
  .clear-btn {
    font-size: 13px; color: #ef4444; background: none;
    border: 1px solid #fecaca; border-radius: 8px; padding: 5px 12px;
    cursor: pointer; font-family: 'DM Sans', sans-serif;
  }

  .history-entry {
    background: white; border-radius: 20px; padding: 18px 20px;
    margin-bottom: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    animation: slideUp 0.3s ease both;
  }
  .history-entry-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
  .history-date { font-size: 13px; font-weight: 600; color: var(--deep); }
  .history-time { font-size: 12px; color: var(--muted); margin-top: 1px; }

  .overall-badge {
    font-size: 11px; font-weight: 700; padding: 4px 12px;
    border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px;
  }
  .overall-ok { background: #d1fae5; color: #065f46; }
  .overall-warn { background: #fef3c7; color: #92400e; }
  .overall-bad { background: #fee2e2; color: #991b1b; }

  .history-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
  .history-param { background: var(--surface); border-radius: 10px; padding: 10px 12px; }
  .history-param-label { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.8px; color: var(--muted); margin-bottom: 4px; }
  .history-param-row { display: flex; align-items: center; justify-content: space-between; }
  .history-param-value { font-family: 'Bebas Neue', sans-serif; font-size: 20px; color: var(--text); }
  .mini-badge { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 10px; text-transform: uppercase; }
  .mini-ok { background: #d1fae5; color: #065f46; }
  .mini-low { background: #fef3c7; color: #92400e; }
  .mini-high { background: #fee2e2; color: #991b1b; }
  .mini-unknown { background: #f1f5f9; color: #475569; }
  .history-advice { margin-top: 10px; font-size: 13px; color: var(--muted); line-height: 1.5; padding-top: 10px; border-top: 1px solid #f1f5f9; }

  /* Confidence bar */
  .conf-bar { height: 4px; border-radius: 2px; background: #e0f2fe; margin-top: 5px; overflow: hidden; }
  .conf-bar-fill { height: 100%; border-radius: 2px; background: var(--water); transition: width 0.6s ease; }

  /* ── FOOTER ── */
  .app-footer {
    text-align: center;
    padding: 12px 16px calc(var(--tab-bar-h, 65px) + env(safe-area-inset-bottom) + 16px);
    color: var(--muted);
    font-size: 12px;
    letter-spacing: 0.5px;
  }

  .app-footer .footer-version {
    display: inline-flex; align-items: center; gap: 6px;
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 5px 14px;
    font-size: 12px;
    font-weight: 600;
    color: var(--deep);
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .footer-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #10b981; display: inline-block;
  }

  /* ── UPDATE BUTTON ── */
  .update-banner {
    display: none;
    position: fixed;
    bottom: calc(var(--tab-bar-h, 65px) + env(safe-area-inset-bottom) + 10px);
    left: 12px;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    color: white; border-radius: 14px;
    padding: 10px 14px;
    font-size: 12px; line-height: 1.4;
    align-items: center; gap: 10px;
    z-index: 9998;
    box-shadow: 0 6px 20px rgba(124,58,237,0.4);
    max-width: 220px;
    font-family: 'DM Sans', sans-serif;
    animation: slideUp 0.3s ease both;
  }
  .update-banner.show { display: flex; }

  .update-btn {
    background: white; color: #7c3aed;
    border: none; border-radius: 10px;
    padding: 8px 14px; font-weight: 700;
    font-size: 13px; cursor: pointer;
    white-space: nowrap; font-family: 'DM Sans', sans-serif;
    flex-shrink: 0;
  }

  .footer-update-btn {
    margin-top: 10px;
    display: none;
    background: linear-gradient(135deg, #7c3aed, #a855f7);
    color: white; border: none; border-radius: 20px;
    padding: 7px 18px; font-size: 12px; font-weight: 600;
    cursor: pointer; font-family: 'DM Sans', sans-serif;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 8px rgba(124,58,237,0.3);
    transition: all 0.2s;
  }
  .footer-update-btn.show { display: inline-block; }
  .footer-update-btn:active { transform: scale(0.97); }


  /* ── STRIP SELECT STEP ── */
  #step-strip-select { display: none; }

  .strip-select-hint {
    background: linear-gradient(135deg, #0c4a6e, #0369a1);
    color: white; border-radius: 14px;
    padding: 12px 14px; margin-bottom: 12px;
    font-size: 13px; line-height: 1.5;
    display: flex; align-items: center; gap: 10px;
  }

  .strip-select-hint .hint-icon { font-size: 22px; flex-shrink: 0; }

  .strip-confirm-overlay {
    display: none;
    background: #10b981; color: white;
    border-radius: 14px; padding: 10px 14px;
    margin-top: 10px; font-size: 13px; font-weight: 600;
    text-align: center; animation: slideUp 0.2s ease both;
  }

</style>
</head>
<body>

<div class="header">
  <h1>PoolCheck</h1>
  <p>Vision-Based Water Analysis</p>
</div>

<div id="app-body" style="flex:1;display:flex;flex-direction:column;overflow:hidden;">

<div class="tab-nav">
  <button class="tab-btn active" id="tab-analyze" onclick="showTab('analyze')">📸 Analyze</button>
  <button class="tab-btn" id="tab-history" onclick="showTab('history')">
    📋 History <span class="hc" id="history-count">0</span>
  </button>
</div>

<!-- ANALYZE PAGE -->
<div class="page active" id="page-analyze">
  <div class="scroll-area">
  <div class="main">

    <div class="upload-card">
      <!-- Step 1: upload -->
      <div id="step-upload">
        <div class="upload-zone" id="upload-zone">
          <input type="file" accept="image/*" capture="environment" id="file-input">
          <span class="upload-icon">📸</span>
          <h3>Photograph Your Test Strip</h3>
          <p>Hold the strip flat in good lighting, strip facing up</p>
        </div>
      </div>


      <!-- Step 1b: select strip region -->
      <div id="step-strip-select">
        <div class="strip-select-hint">
          <span class="hint-icon">✂️</span>
          <span>Draw a box tightly around your <strong>test strip</strong> to zoom in before marking each pad</span>
        </div>

        <div id="strip-full-wrap" style="position:relative;border-radius:14px;overflow:hidden;margin-bottom:10px;cursor:crosshair;touch-action:none;">
          <canvas id="strip-full-canvas"></canvas>
          <button class="change-btn" onclick="resetAll()">✕ Start Over</button>
        </div>

        <div class="strip-confirm-overlay" id="strip-confirm-overlay">
          ✅ Strip region selected — zooming in…
        </div>
      </div>

      <!-- Step 2: mark pads -->
      <div id="step-mark" style="display:none">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1.5px;color:var(--deep);margin-bottom:8px;" id="mark-title">
          📍 Mark the <span id="current-pad-name">pH</span> Pad
        </div>

        <div class="instruction-row">
          <span class="icon">👆</span>
          <span id="mark-instruction">Tap and drag a box around the <strong>pH color pad</strong> on the strip</span>
        </div>

        <div id="strip-preview-wrap">
          <canvas id="strip-canvas"></canvas>
          <div id="selection-box" class="selection-box"></div>
          <button class="change-btn" onclick="resetAll()">✕ Start Over</button>
        </div>

        <!-- Progress dots -->
        <div class="steps-indicator" style="margin-top:12px;" id="step-dots"></div>

        <!-- Sampled swatches so far -->
        <div class="swatch-row" id="swatch-row"></div>

        <button class="wizard-btn secondary" onclick="resetAll()">↩ Retake Photo</button>
      </div>

      <!-- Analyze button (shown after all pads marked) -->
      <button class="analyze-btn" id="analyze-btn" onclick="analyzeStrip()">
        ⚗️ Analyze Colors
      </button>

      <div class="error-card" id="error-card"></div>
    </div>

    <div id="results">
      <div class="results-header">Your Results</div>
      <div id="params-container"></div>
      <div class="advice-card">
        <h3>💡 Recommendations</h3>
        <p id="advice-text"></p>
      </div>
      <button class="new-test-btn" onclick="resetAll()">🔄 Test Again</button>
    </div>
  </div>
  </div>
</div>

<!-- HISTORY PAGE -->
<div class="page" id="page-history">
  <div class="scroll-area">
  <div class="main">
    <div id="history-container"></div>
  </div>
  </div>
</div>

<canvas id="offscreen" style="display:none"></canvas>

<script>
// ═══════════════════════════════════════════════════════
//  COLOR SCIENCE HELPERS
// ═══════════════════════════════════════════════════════

// sRGB → linear
function linearize(c) {
  c /= 255;
  return c <= 0.04045 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
}

// RGB → CIE XYZ (D65)
function rgbToXyz(r, g, b) {
  r = linearize(r); g = linearize(g); b = linearize(b);
  return {
    x: r*0.4124564 + g*0.3575761 + b*0.1804375,
    y: r*0.2126729 + g*0.7151522 + b*0.0721750,
    z: r*0.0193339 + g*0.1191920 + b*0.9503041
  };
}

// XYZ → CIELAB
function xyzToLab(x, y, z) {
  const xn=0.95047, yn=1.00000, zn=1.08883;
  function f(t) { return t > 0.008856 ? Math.cbrt(t) : 7.787*t + 16/116; }
  const fx=f(x/xn), fy=f(y/yn), fz=f(z/zn);
  return { L: 116*fy-16, a: 500*(fx-fy), b: 200*(fy-fz) };
}

function rgbToLab(r, g, b) {
  const xyz = rgbToXyz(r, g, b);
  return xyzToLab(xyz.x, xyz.y, xyz.z);
}

// CIE76 color distance
function deltaE(lab1, lab2) {
  return Math.sqrt(
    Math.pow(lab1.L - lab2.L, 2) +
    Math.pow(lab1.a - lab2.a, 2) +
    Math.pow(lab1.b - lab2.b, 2)
  );
}

// ═══════════════════════════════════════════════════════
//  REFERENCE COLOR DATABASE  (Hach 4-in-1 strip)
//  Colors sampled from the bottle label photo
// ═══════════════════════════════════════════════════════
const REFS = {
  ph: [
    { value: '6.2', label: '6.2', rgb: [190, 130, 85],  status: 'low'  },
    { value: '6.8', label: '6.8', rgb: [210, 115, 60],  status: 'low'  },
    { value: '7.2', label: '7.2', rgb: [215, 105, 80],  status: 'ok'   },
    { value: '7.8', label: '7.8', rgb: [200, 85,  95],  status: 'ok'   },
    { value: '8.4', label: '8.4', rgb: [185, 65,  75],  status: 'high' },
  ],
  chlorine: [
    { value: '0',   label: '0 ppm',   rgb: [230, 220, 195], status: 'low'  },
    { value: '0.5', label: '0.5 ppm', rgb: [210, 195, 210], status: 'low'  },
    { value: '1',   label: '1 ppm',   rgb: [190, 170, 210], status: 'ok'   },
    { value: '3',   label: '3 ppm',   rgb: [160, 130, 195], status: 'ok'   },
    { value: '5',   label: '5 ppm',   rgb: [130, 100, 180], status: 'high' },
    { value: '10',  label: '10 ppm',  rgb: [100,  70, 155], status: 'high' },
  ],
  alkalinity: [
    { value: '0',   label: '0 ppm',   rgb: [195, 155, 90],  status: 'low'  },
    { value: '40',  label: '40 ppm',  rgb: [155, 145, 80],  status: 'low'  },
    { value: '80',  label: '80 ppm',  rgb: [110, 125, 85],  status: 'ok'   },
    { value: '120', label: '120 ppm', rgb: [80,  135, 120], status: 'ok'   },
    { value: '180', label: '180 ppm', rgb: [55,  120, 130], status: 'high' },
    { value: '240', label: '240 ppm', rgb: [40,  105, 115], status: 'high' },
  ],
  stabilizer: [
    { value: '0',     label: '0 ppm',    rgb: [195, 155, 90],  status: 'low'  },
    { value: '30-50', label: '30-50 ppm',rgb: [185, 140, 145], status: 'ok'   },
    { value: '100',   label: '100 ppm',  rgb: [175, 110, 155], status: 'high' },
    { value: '150',   label: '150 ppm',  rgb: [150, 90,  150], status: 'high' },
    { value: '300',   label: '300 ppm',  rgb: [120, 65,  130], status: 'high' },
  ]
};

// Pre-compute Lab values for all references
Object.values(REFS).forEach(arr => {
  arr.forEach(r => { r.lab = rgbToLab(...r.rgb); });
});

// Pad order for the marking wizard
const PAD_ORDER = ['ph', 'chlorine', 'alkalinity', 'stabilizer'];
const PAD_LABELS = { ph: 'pH', chlorine: 'Free Chlorine', alkalinity: 'Total Alkalinity', stabilizer: 'Stabilizer (CYA)' };
const PAD_EMOJI  = { ph: '🧪', chlorine: '💧', alkalinity: '⚗️', stabilizer: '☀️' };
const PAD_INSTRUCTIONS = {
  ph:         'Tap and drag a box around the <strong>pH color pad</strong> (usually the bottom/end pad)',
  chlorine:   'Tap and drag a box around the <strong>Free Chlorine pad</strong>',
  alkalinity: 'Tap and drag a box around the <strong>Total Alkalinity pad</strong>',
  stabilizer: 'Tap and drag a box around the <strong>Stabilizer / CYA pad</strong> (top pad)'
};
const PARAM_UNITS  = { ph: '', chlorine: ' ppm', alkalinity: ' ppm', stabilizer: ' ppm' };
const PARAM_RANGES = { ph: 'OK: 7.2–7.8', chlorine: 'Pool OK: 1–3 ppm', alkalinity: 'OK: 80–120 ppm', stabilizer: 'Ideal: 30–50 ppm' };
const STATUS_LABELS = { ok: 'OK', low: 'LOW', high: 'HIGH', unknown: '?' };
const HISTORY_KEY = 'poolcheck-v2-history';
// ── App Version (single source of truth — update this + sw.js CACHE together) ──
const APP_VERSION = 'v8';

// ═══════════════════════════════════════════════════════
//  STATE
// ═══════════════════════════════════════════════════════
let imgElement = null;
let naturalW = 0, naturalH = 0;
let canvasDisplayW = 0, canvasDisplayH = 0;
let scaleX = 1, scaleY = 1;

let currentPadIndex = 0;
let padRegions = {};   // { ph: {x,y,w,h} in natural coords, ... }
let sampledColors = {};// { ph: {r,g,b}, ... }

// Selection drag state
let isDragging = false;
let dragStart = { x: 0, y: 0 };
let dragCurrent = { x: 0, y: 0 };
let currentRegion = null; // {x,y,w,h} in display coords

// ═══════════════════════════════════════════════════════
//  CANVAS + IMAGE SETUP
// ═══════════════════════════════════════════════════════
// ── Strip selection canvas (full image, draw box around strip) ──
const stripFullCanvas = document.getElementById('strip-full-canvas');
const sCtx = stripFullCanvas ? stripFullCanvas.getContext('2d', { willReadFrequently: true }) : null;

// Shared drag state for strip-full-canvas
let sfDragging = false, sfDragStart = {x:0,y:0}, sfDragCurrent = {x:0,y:0}, sfRegion = null;

function sfGetPos(e) {
  const rect = stripFullCanvas.getBoundingClientRect();
  const cx = e.touches ? e.touches[0].clientX : e.clientX;
  const cy = e.touches ? e.touches[0].clientY : e.clientY;
  return {
    x: (cx - rect.left) * (stripFullCanvas.width / rect.width),
    y: (cy - rect.top)  * (stripFullCanvas.height / rect.height)
  };
}

function sfDrawCanvas() {
  sCtx.drawImage(imgElement, 0, 0, stripFullCanvas.width, stripFullCanvas.height);
  if (sfRegion) {
    const {x,y,w,h} = sfRegion;
    sCtx.strokeStyle = '#facc15'; sCtx.lineWidth = 2;
    sCtx.setLineDash([4,3]);
    sCtx.strokeRect(x,y,w,h);
    sCtx.fillStyle = 'rgba(250,204,21,0.15)';
    sCtx.fillRect(x,y,w,h);
    sCtx.setLineDash([]);
  }
}

function sfOnStart(e) {
  e.preventDefault(); sfDragging = true;
  sfDragStart = sfGetPos(e); sfDragCurrent = {...sfDragStart}; sfRegion = null;
}
function sfOnMove(e) {
  if (!sfDragging) return; e.preventDefault();
  sfDragCurrent = sfGetPos(e);
  const x = Math.min(sfDragStart.x, sfDragCurrent.x);
  const y = Math.min(sfDragStart.y, sfDragCurrent.y);
  sfRegion = { x, y, w: Math.abs(sfDragCurrent.x - sfDragStart.x), h: Math.abs(sfDragCurrent.y - sfDragStart.y) };
  sfDrawCanvas();
}
function sfOnEnd(e) {
  if (!sfDragging) return; sfDragging = false;
  if (!sfRegion || sfRegion.w < 15 || sfRegion.h < 15) { sfRegion = null; sfDrawCanvas(); return; }
  // Valid strip region — convert to natural coords and confirm
  const sfScaleX = naturalW / stripFullCanvas.width;
  const sfScaleY = naturalH / stripFullCanvas.height;
  stripRegion = {
    x: Math.round(Math.max(0, sfRegion.x * sfScaleX)),
    y: Math.round(Math.max(0, sfRegion.y * sfScaleY)),
    w: Math.round(Math.min(sfRegion.w * sfScaleX, naturalW)),
    h: Math.round(Math.min(sfRegion.h * sfScaleY, naturalH))
  };
  document.getElementById('strip-confirm-overlay').style.display = 'block';
  setTimeout(() => enterPadMarking(), 500);
}

function enterPadMarking() {
  document.getElementById('step-strip-select').style.display = 'none';
  document.getElementById('step-mark').style.display = 'block';
  previewWrap.style.display = 'block';

  // Set the pad-marking canvas to show ONLY the strip region
  const maxW = 800;
  const scale = Math.min(1, maxW / stripRegion.w);
  stripCanvas.width  = Math.round(stripRegion.w * scale);
  stripCanvas.height = Math.round(stripRegion.h * scale);
  canvasDisplayW = stripCanvas.width;
  canvasDisplayH = stripCanvas.height;
  // scaleX/Y now relative to the strip region, not the full image
  scaleX = stripRegion.w / canvasDisplayW;
  scaleY = stripRegion.h / canvasDisplayH;

  // Draw just the strip region
  ctx.drawImage(imgElement,
    stripRegion.x, stripRegion.y, stripRegion.w, stripRegion.h,
    0, 0, canvasDisplayW, canvasDisplayH
  );

  // Pad coordinates will be relative to strip region origin
  currentPadIndex = 0; padRegions = {}; sampledColors = {}; zoomRegion = null;
  updateMarkUI();
}

const stripCanvas = document.getElementById('strip-canvas');
const ctx = stripCanvas.getContext('2d', { willReadFrequently: true });
const selBox = document.getElementById('selection-box');
const previewWrap = document.getElementById('strip-preview-wrap');
const offscreen = document.getElementById('offscreen');
const offCtx = offscreen.getContext('2d', { willReadFrequently: true });

function loadImageToCanvas(file) {
  const url = URL.createObjectURL(file);
  imgElement = new Image();
  imgElement.onload = () => {
    naturalW = imgElement.naturalWidth;
    naturalH = imgElement.naturalHeight;

    // Fit to max 800px wide maintaining aspect ratio
    const maxW = 800;
    const scale = Math.min(1, maxW / naturalW);
    stripCanvas.width  = Math.round(naturalW * scale);
    stripCanvas.height = Math.round(naturalH * scale);

    // Draw full image to offscreen at native resolution for accurate sampling
    offscreen.width  = naturalW;
    offscreen.height = naturalH;
    offCtx.drawImage(imgElement, 0, 0);

    // Draw to display canvas
    ctx.drawImage(imgElement, 0, 0, stripCanvas.width, stripCanvas.height);

    canvasDisplayW = stripCanvas.width;
    canvasDisplayH = stripCanvas.height;
    scaleX = naturalW / canvasDisplayW;
    scaleY = naturalH / canvasDisplayH;

    URL.revokeObjectURL(url);
    showMarkStep();
  };
  imgElement.src = url;
}

// ═══════════════════════════════════════════════════════
//  MARK STEP UI
// ═══════════════════════════════════════════════════════
function showMarkStep() {
  // First show full image for strip region selection
  document.getElementById('step-upload').style.display = 'none';
  document.getElementById('step-strip-select').style.display = 'block';
  document.getElementById('strip-confirm-overlay').style.display = 'none';
  sfRegion = null; stripRegion = null;

  // Size the strip-full-canvas to fit display
  const maxW = 800;
  const scale = Math.min(1, maxW / naturalW);
  stripFullCanvas.width  = Math.round(naturalW * scale);
  stripFullCanvas.height = Math.round(naturalH * scale);
  sCtx.drawImage(imgElement, 0, 0, stripFullCanvas.width, stripFullCanvas.height);
}

function updateMarkUI() {
  const key = PAD_ORDER[currentPadIndex];
  document.getElementById('current-pad-name').textContent = PAD_LABELS[key];
  document.getElementById('mark-instruction').innerHTML = PAD_INSTRUCTIONS[key];

  currentRegion = null;

  // Dots
  const dots = document.getElementById('step-dots');
  dots.innerHTML = PAD_ORDER.map((k, i) =>
    `<div class="step-dot ${i < currentPadIndex ? 'done' : i === currentPadIndex ? 'active' : ''}"></div>`
  ).join('');

  // Swatches of already-sampled pads
  const sr = document.getElementById('swatch-row');
  sr.innerHTML = PAD_ORDER.slice(0, currentPadIndex).map(k => {
    const c = sampledColors[k];
    const hex = c ? rgbToHex(c.r, c.g, c.b) : '#ccc';
    return `<div class="swatch" style="background:${hex}" title="${PAD_LABELS[k]}">${PAD_EMOJI[k]}</div>`;
  }).join('');

  // Redraw canvas with existing markers
  redrawCanvas();
}

// Zoom viewport — null means full image, otherwise {x,y,w,h} in natural coords
let zoomRegion = null;

function computeZoomRegion() {
  // Build bounding box of all confirmed pads with padding
  const confirmed = PAD_ORDER.slice(0, currentPadIndex).map(k => padRegions[k]).filter(Boolean);
  if (confirmed.length === 0) { zoomRegion = null; return; }
  let minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
  confirmed.forEach(r => {
    minX = Math.min(minX, r.x); minY = Math.min(minY, r.y);
    maxX = Math.max(maxX, r.x + r.w); maxY = Math.max(maxY, r.y + r.h);
  });
  // Add generous padding (20% of strip span)
  const padX = Math.max(30, (maxX - minX) * 0.25);
  const padY = Math.max(30, (maxY - minY) * 0.25);
  zoomRegion = {
    x: Math.max(0, Math.round(minX - padX)),
    y: Math.max(0, Math.round(minY - padY)),
    w: Math.min(naturalW, Math.round((maxX - minX) + padX * 2)),
    h: Math.min(naturalH, Math.round((maxY - minY) + padY * 2))
  };
  // Clamp to image bounds
  zoomRegion.w = Math.min(zoomRegion.w, naturalW - zoomRegion.x);
  zoomRegion.h = Math.min(zoomRegion.h, naturalH - zoomRegion.y);
}

function redrawCanvas() {
  const zoom = zoomRegion;

  if (zoom) {
    // Draw zoomed crop: source = zoom region in natural px, dest = full canvas
    ctx.drawImage(imgElement,
      zoom.x, zoom.y, zoom.w, zoom.h,
      0, 0, canvasDisplayW, canvasDisplayH
    );
    // Scale factors for this zoomed view
    const zScaleX = zoom.w / canvasDisplayW;
    const zScaleY = zoom.h / canvasDisplayH;

    // Draw confirmed pad markers (in zoomed coords)
    PAD_ORDER.slice(0, currentPadIndex).forEach(k => {
      const r = padRegions[k];
      if (!r) return;
      const dx = (r.x - zoom.x) / zScaleX;
      const dy = (r.y - zoom.y) / zScaleY;
      const dw = r.w / zScaleX;
      const dh = r.h / zScaleY;
      ctx.strokeStyle = '#10b981'; ctx.lineWidth = 2;
      ctx.strokeRect(dx, dy, dw, dh);
      ctx.fillStyle = 'rgba(16,185,129,0.18)'; ctx.fillRect(dx, dy, dw, dh);
      ctx.fillStyle = '#10b981'; ctx.font = 'bold 11px DM Sans, sans-serif';
      ctx.fillText(PAD_LABELS[k], dx + 3, dy + 13);
    });

    // Draw current drag selection (already in display coords)
    if (currentRegion) {
      const { x, y, w, h } = currentRegion;
      ctx.strokeStyle = '#facc15'; ctx.lineWidth = 2;
      ctx.setLineDash([4, 3]);
      ctx.strokeRect(x, y, w, h);
      ctx.fillStyle = 'rgba(250,204,21,0.18)'; ctx.fillRect(x, y, w, h);
      ctx.setLineDash([]);
    }
  } else {
    // Full image view (first pad selection)
    ctx.drawImage(imgElement, 0, 0, canvasDisplayW, canvasDisplayH);

    // Draw current drag selection
    if (currentRegion) {
      const { x, y, w, h } = currentRegion;
      ctx.strokeStyle = '#facc15'; ctx.lineWidth = 2;
      ctx.setLineDash([4, 3]);
      ctx.strokeRect(x, y, w, h);
      ctx.fillStyle = 'rgba(250,204,21,0.18)'; ctx.fillRect(x, y, w, h);
      ctx.setLineDash([]);
    }
  }
}

// ═══════════════════════════════════════════════════════
//  DRAG SELECTION — mouse + touch
// ═══════════════════════════════════════════════════════
function getCanvasPos(e) {
  const rect = stripCanvas.getBoundingClientRect();
  const clientX = e.touches ? e.touches[0].clientX : e.clientX;
  const clientY = e.touches ? e.touches[0].clientY : e.clientY;
  // Scale from CSS pixels to canvas pixels
  return {
    x: (clientX - rect.left) * (canvasDisplayW / rect.width),
    y: (clientY - rect.top)  * (canvasDisplayH / rect.height)
  };
}

function onDragStart(e) {
  e.preventDefault();
  isDragging = true;
  dragStart = getCanvasPos(e);
  dragCurrent = { ...dragStart };
  currentRegion = null;

}

function onDragMove(e) {
  if (!isDragging) return;
  e.preventDefault();
  dragCurrent = getCanvasPos(e);
  const x = Math.min(dragStart.x, dragCurrent.x);
  const y = Math.min(dragStart.y, dragCurrent.y);
  const w = Math.abs(dragCurrent.x - dragStart.x);
  const h = Math.abs(dragCurrent.y - dragStart.y);
  currentRegion = { x, y, w, h };
  redrawCanvas();
}

function onDragEnd(e) {
  if (!isDragging) return;
  isDragging = false;
  if (!currentRegion || currentRegion.w < 8 || currentRegion.h < 8) {
    currentRegion = null;
    redrawCanvas();
    return;
  }
  // Valid region — flash green then auto-advance after brief pause
  redrawCanvas();
  setTimeout(() => confirmPad(), 380);
}

stripFullCanvas.addEventListener('mousedown',  sfOnStart);
stripFullCanvas.addEventListener('mousemove',  sfOnMove);
stripFullCanvas.addEventListener('mouseup',    sfOnEnd);
stripFullCanvas.addEventListener('touchstart', sfOnStart, { passive: false });
stripFullCanvas.addEventListener('touchmove',  sfOnMove,  { passive: false });
stripFullCanvas.addEventListener('touchend',   sfOnEnd);

stripCanvas.addEventListener('mousedown',  onDragStart);
stripCanvas.addEventListener('mousemove',  onDragMove);
stripCanvas.addEventListener('mouseup',    onDragEnd);
stripCanvas.addEventListener('touchstart', onDragStart, { passive: false });
stripCanvas.addEventListener('touchmove',  onDragMove,  { passive: false });
stripCanvas.addEventListener('touchend',   onDragEnd);

// ═══════════════════════════════════════════════════════
//  CONFIRM PAD — sample color from region
// ═══════════════════════════════════════════════════════
function confirmPad() {
  if (!currentRegion) return;
  const key = PAD_ORDER[currentPadIndex];

  // Store region in natural image coordinates
  padRegions[key] = {
    x: Math.round(currentRegion.x * scaleX),
    y: Math.round(currentRegion.y * scaleY),
    w: Math.round(currentRegion.w * scaleX),
    h: Math.round(currentRegion.h * scaleY)
  };

  // Sample median color from the region
  sampledColors[key] = sampleMedianColor(padRegions[key]);

  currentPadIndex++;

  // Update zoom to show tight crop around confirmed pads
  computeZoomRegion();

  if (currentPadIndex >= PAD_ORDER.length) {
    // All pads marked — draw final state then auto-analyze
    document.getElementById('step-mark').style.display = 'none';
    redrawCanvas();
    // Brief pause so user sees last confirmed pad, then analyze
    setTimeout(() => analyzeStrip(), 450);
  } else {
    updateMarkUI();
  }
}

// ═══════════════════════════════════════════════════════
//  COLOR SAMPLING — median of pixels in region
// ═══════════════════════════════════════════════════════
function sampleMedianColor(region) {
  // region coords are relative to stripRegion — offset to full image coords
  const ox = stripRegion ? stripRegion.x : 0;
  const oy = stripRegion ? stripRegion.y : 0;
  const { x, y, w, h } = region;
  const safeX = Math.max(0, x + ox);
  const safeY = Math.max(0, y + oy);
  const safeW = Math.min(w, offscreen.width  - safeX);
  const safeH = Math.min(h, offscreen.height - safeY);

  if (safeW <= 0 || safeH <= 0) return { r: 128, g: 128, b: 128 };

  const imgData = offCtx.getImageData(safeX, safeY, safeW, safeH);
  const pixels = imgData.data;

  const rs = [], gs = [], bs = [];
  for (let i = 0; i < pixels.length; i += 4) {
    rs.push(pixels[i]);
    gs.push(pixels[i+1]);
    bs.push(pixels[i+2]);
  }

  rs.sort((a,b) => a-b);
  gs.sort((a,b) => a-b);
  bs.sort((a,b) => a-b);

  const mid = Math.floor(rs.length / 2);
  return { r: rs[mid], g: gs[mid], b: bs[mid] };
}

// ═══════════════════════════════════════════════════════
//  ANALYSIS — match each sampled color to nearest ref
// ═══════════════════════════════════════════════════════
function analyzeStrip() {
  const results = {};

  PAD_ORDER.forEach(key => {
    const sampled = sampledColors[key];
    if (!sampled) { results[key] = { value: '—', status: 'unknown', confidence: 0, rgb: [128,128,128] }; return; }

    const sampledLab = rgbToLab(sampled.r, sampled.g, sampled.b);
    const refs = REFS[key];

    // Find closest reference color
    let best = null, bestDist = Infinity;
    refs.forEach(ref => {
      const d = deltaE(sampledLab, ref.lab);
      if (d < bestDist) { bestDist = d; best = ref; }
    });

    // Confidence: deltaE < 10 = high, < 20 = medium, >= 20 = low
    // Map to 0-100%
    const confidence = Math.max(0, Math.min(100, Math.round((1 - bestDist / 40) * 100)));

    results[key] = {
      value: best.value,
      label: best.label,
      status: confidence < 25 ? 'unknown' : best.status,
      confidence,
      deltaE: Math.round(bestDist),
      rgb: [sampled.r, sampled.g, sampled.b],
      hexColor: rgbToHex(sampled.r, sampled.g, sampled.b)
    };
  });

  displayResults(results);
  addToHistory(results);
}

// ═══════════════════════════════════════════════════════
//  DISPLAY RESULTS
// ═══════════════════════════════════════════════════════
function displayResults(results) {
  const container = document.getElementById('params-container');
  container.innerHTML = '';

  const adviceParts = [];

  PAD_ORDER.forEach(key => {
    const r = results[key] || { value: '—', status: 'unknown', confidence: 0 };
    const card = document.createElement('div');
    card.className = `param-card status-${r.status}`;

    const confPct = r.confidence || 0;
    const confLabel = confPct >= 70 ? '🟢 High confidence' : confPct >= 40 ? '🟡 Medium confidence' : '🔴 Low confidence — re-mark pad';
    const unit = PARAM_UNITS[key] || '';

    card.innerHTML = `
      <div class="status-dot">
        ${PAD_EMOJI[key]}
        ${r.hexColor ? `<div class="color-chip" style="background:${r.hexColor}"></div>` : ''}
      </div>
      <div class="param-info">
        <div class="param-name">${PAD_LABELS[key]}</div>
        <div class="param-value">${r.value}<span class="param-unit">${unit}</span></div>
        <div class="param-range">${PARAM_RANGES[key]}</div>
        <div class="conf-bar"><div class="conf-bar-fill" style="width:${confPct}%"></div></div>
        <div class="param-confidence" style="color:var(--muted);font-size:11px">${confLabel}</div>
      </div>
      <div class="status-badge">${STATUS_LABELS[r.status] || '?'}</div>`;

    container.appendChild(card);

    if (r.status === 'low')  adviceParts.push(`${PAD_LABELS[key]} is low (${r.value}${unit}) — add the appropriate chemical to raise it.`);
    if (r.status === 'high') adviceParts.push(`${PAD_LABELS[key]} is high (${r.value}${unit}) — reduce with the appropriate treatment or partial water change.`);
  });

  const advice = adviceParts.length
    ? adviceParts.join(' ')
    : 'All levels look good! Your pool water is well balanced.';

  document.getElementById('advice-text').textContent = advice;
  document.getElementById('results').style.display = 'block';
  document.getElementById('analyze-btn').style.display = 'none';

  setTimeout(() => document.getElementById('results').scrollIntoView({ behavior: 'smooth', block: 'start' }), 100);
}

// ═══════════════════════════════════════════════════════
//  UTILITIES
// ═══════════════════════════════════════════════════════
function rgbToHex(r, g, b) {
  return '#' + [r, g, b].map(v => v.toString(16).padStart(2, '0')).join('');
}

// ═══════════════════════════════════════════════════════
//  HISTORY
// ═══════════════════════════════════════════════════════
function loadHistory() {
  try { return JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); } catch { return []; }
}

function saveHistory(h) { localStorage.setItem(HISTORY_KEY, JSON.stringify(h)); }

function addToHistory(results) {
  const h = loadHistory();
  const entry = { id: Date.now(), timestamp: new Date().toISOString() };
  PAD_ORDER.forEach(k => { entry[k] = { value: results[k]?.value || '—', status: results[k]?.status || 'unknown' }; });
  h.unshift(entry);
  saveHistory(h);
  updateHistoryCount();
}

function updateHistoryCount() {
  document.getElementById('history-count').textContent = loadHistory().length;
}

function renderHistory() {
  const container = document.getElementById('history-container');
  const entries = loadHistory();

  if (!entries.length) {
    container.innerHTML = `<div class="history-empty"><div class="ei">🏊</div><h3>No tests yet</h3><p>Analyze your first strip to start tracking.</p></div>`;
    return;
  }

  container.innerHTML = `
    <div class="history-toolbar">
      <div class="history-title">History</div>
      <button class="clear-btn" onclick="clearHistory()">🗑 Clear All</button>
    </div>
    <div id="history-list"></div>`;

  const list = document.getElementById('history-list');
  entries.forEach((entry, idx) => {
    const date = new Date(entry.timestamp);
    const dateStr = date.toLocaleDateString('en-CA', { weekday:'short', month:'short', day:'numeric', year:'numeric' });
    const timeStr = date.toLocaleTimeString('en-CA', { hour:'2-digit', minute:'2-digit' });
    const statuses = PAD_ORDER.map(k => entry[k]?.status || 'unknown');
    const hasHigh = statuses.includes('high');
    const hasLow  = statuses.includes('low');
    const oc = hasHigh ? 'overall-bad' : hasLow ? 'overall-warn' : 'overall-ok';
    const ol = hasHigh ? '⚠️ Issues' : hasLow ? '⬇️ Low' : '✅ All OK';

    const el = document.createElement('div');
    el.className = 'history-entry';
    el.style.animationDelay = (idx * 0.04) + 's';

    el.innerHTML = `
      <div class="history-entry-header">
        <div><div class="history-date">${dateStr}</div><div class="history-time">${timeStr}</div></div>
        <div class="overall-badge ${oc}">${ol}</div>
      </div>
      <div class="history-grid">
        ${PAD_ORDER.map(k => {
          const item = entry[k] || { value:'—', status:'unknown' };
          const unit = PARAM_UNITS[k] || '';
          return `<div class="history-param">
            <div class="history-param-label">${PAD_EMOJI[k]} ${PAD_LABELS[k]}</div>
            <div class="history-param-row">
              <div class="history-param-value">${item.value}<span style="font-size:11px;color:var(--muted)">${unit}</span></div>
              <div class="mini-badge mini-${item.status}">${STATUS_LABELS[item.status]||'?'}</div>
            </div>
          </div>`;
        }).join('')}
      </div>`;
    list.appendChild(el);
  });
}

function clearHistory() {
  if (!confirm('Clear all test history? This cannot be undone.')) return;
  saveHistory([]);
  updateHistoryCount();
  renderHistory();
}

// ═══════════════════════════════════════════════════════
//  TAB + FILE INPUT + RESET
// ═══════════════════════════════════════════════════════
function showTab(tab) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + tab).classList.add('active');
  document.getElementById('tab-' + tab).classList.add('active');
  if (tab === 'history') renderHistory();
}

document.getElementById('file-input').addEventListener('change', e => {
  const file = e.target.files[0];
  if (file) loadImageToCanvas(file);
});

function resetAll() {
  // Reset state
  imgElement = null; currentPadIndex = 0; padRegions = {}; sampledColors = {}; currentRegion = null; isDragging = false;
  // Reset UI
  document.getElementById('step-upload').style.display = 'block';
  document.getElementById('step-strip-select').style.display = 'none';
  document.getElementById('step-mark').style.display = 'none';
  document.getElementById('strip-preview-wrap').style.display = 'none';
  document.getElementById('analyze-btn').style.display = 'none';
  document.getElementById('results').style.display = 'none';
  document.getElementById('error-card').style.display = 'none';
  document.getElementById('params-container').innerHTML = '';
  document.getElementById('file-input').value = '';
  document.getElementById('swatch-row').innerHTML = '';
}

// Init
updateHistoryCount();

// Measure tab bar height and set CSS variable for scroll clearance
function measureTabBar() {
  const nav = document.querySelector('.tab-nav');
  if (nav) {
    document.documentElement.style.setProperty('--tab-bar-h', nav.offsetHeight + 'px');
  }
}
window.addEventListener('resize', measureTabBar);
window.addEventListener('load', measureTabBar);
setTimeout(measureTabBar, 100);

document.querySelectorAll('.app-version').forEach(el => el.textContent = APP_VERSION);

// ── PWA Service Worker ──
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js').catch(() => {});
  });
}

// ── Install Banner ──
let deferredPrompt = null;
window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  showInstallBanner();
});
window.addEventListener('appinstalled', () => { hideInstallBanner(); });

function showInstallBanner() {
  let b = document.getElementById('install-banner');
  if (!b) {
    b = document.createElement('div');
    b.id = 'install-banner';
    b.style.cssText = 'position:fixed;bottom:16px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,#065f46,#10b981);color:white;border-radius:16px;padding:14px 18px;font-size:13px;line-height:1.4;display:flex;align-items:center;gap:12px;z-index:9999;box-shadow:0 8px 24px rgba(0,0,0,0.2);max-width:360px;width:calc(100% - 32px);font-family:DM Sans,sans-serif;';
    b.innerHTML = '<div style="flex:1"><strong style="display:block;font-size:14px;margin-bottom:2px">📲 Install PoolCheck</strong>Add to home screen for offline use</div><button onclick="installPWA()" style="background:white;color:#065f46;border:none;border-radius:10px;padding:8px 14px;font-weight:700;font-size:13px;cursor:pointer;white-space:nowrap">Install</button><button onclick="hideInstallBanner()" style="background:none;border:none;color:rgba(255,255,255,0.7);font-size:20px;cursor:pointer;padding:2px 4px;line-height:1">×</button>';
    document.body.appendChild(b);
  }
  b.style.display = 'flex';
}

function hideInstallBanner() {
  const b = document.getElementById('install-banner');
  if (b) b.style.display = 'none';
}

async function installPWA() {
  if (!deferredPrompt) return;
  deferredPrompt.prompt();
  await deferredPrompt.userChoice;
  deferredPrompt = null;
  hideInstallBanner();
}

// ── Update checker ──
let newSWRegistration = null;

async function checkForUpdate() {
  if (!('serviceWorker' in navigator)) return;
  try {
    const reg = await navigator.serviceWorker.getRegistration();
    if (!reg) return;

    reg.addEventListener('updatefound', () => {
      const newSW = reg.installing;
      newSW.addEventListener('statechange', () => {
        if (newSW.state === 'installed' && navigator.serviceWorker.controller) {
          // New version waiting — show update UI
          newSWRegistration = reg;
          showUpdateUI();
        }
      });
    });

    // Also check immediately
    await reg.update();
  } catch(e) {}
}

function showUpdateUI() {
  document.getElementById('update-banner').classList.add('show');
  document.getElementById('footer-update-btn').classList.add('show');
  // Change footer dot to purple to signal update available
  document.getElementById('footer-dot').style.background = '#a855f7';
}

function applyUpdate() {
  if (newSWRegistration && newSWRegistration.waiting) {
    // Tell the waiting SW to take over
    newSWRegistration.waiting.postMessage({ type: 'SKIP_WAITING' });
  }
  // Reload once the new SW takes control
  navigator.serviceWorker.addEventListener('controllerchange', () => {
    window.location.reload();
  });
  // Fallback reload after short delay
  setTimeout(() => window.location.reload(), 1000);
}

// Run update check on load
window.addEventListener('load', () => {
  checkForUpdate();
  // Recheck every 5 minutes in background
  setInterval(checkForUpdate, 5 * 60 * 1000);
});

</script>


<!-- Update banner -->
<div class="update-banner" id="update-banner">
  <div style="flex:1"><strong style="display:block;font-size:14px;margin-bottom:2px">🔄 Update Available</strong>A new version of PoolCheck is ready</div>
  <button class="update-btn" onclick="applyUpdate()">Update Now</button>
</div>

