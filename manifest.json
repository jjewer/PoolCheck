    <span class="footer-dot" id="footer-dot"></span>
    PoolCheck &nbsp;·&nbsp; <span class="app-version">v8</span>
  </div>
  <button class="footer-update-btn" id="footer-update-btn" onclick="applyUpdate()">⬆ Update App</button>
</div>
